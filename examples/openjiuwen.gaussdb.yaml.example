user_id: context-agent

llm_config:
  provider: openai
  model: gpt-4o-mini
  api_key: ${OPENAI_API_KEY}
  base_url: https://api.openai.com/v1
  timeout: 30
  max_retries: 2

embedding_config:
  provider: openai
  model: text-embedding-3-large
  api_key: ${OPENAI_API_KEY}
  base_url: https://api.openai.com/v1
  dimension: 3072
  batch_size: 32

vector_store:
  # 对于本地部署 GaussDB / openGauss 体系，推荐通过 openJiuwen
  # 按 pgvector 兼容方式接入，而不是让 ContextAgent 直连数据库。
  backend: pgvector
  dsn: postgresql://gauss_user:password@127.0.0.1:5432/context_agent?sslmode=disable
  schema: public
  table_name: ltm_memory
  embedding_dimension: 3072
  distance: cosine
  index_type: ivfflat
  lists: 100
  metadata_fields:
    - scope_id
    - session_id
    - memory_type
    - source
    - created_at
    - updated_at
    - tags

memory_config:
  top_k: 10
  score_threshold: 0.3
  enable_user_profile: true
  enable_semantic_memory: true
  enable_episodic_memory: true
  enable_summary_memory: true

runtime:
  write_batch_size: 16
  search_timeout_ms: 300
  healthcheck_query: "select 1"

notes:
  deployment_mode: local-gaussdb
  guidance:
    - Ensure the local GaussDB deployment exposes PostgreSQL/openGauss compatible access.
    - Ensure vector type and vector index capability are installed/enabled in the database.
    - If your GaussDB distribution uses custom extension names or index syntax, adapt them in openJiuwen, not in ContextAgent.
